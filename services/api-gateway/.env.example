PORT=8080
FAMILY_SERVICE_URL=http://localhost:8081
CALENDAR_SERVICE_URL=http://localhost:8082
TASKS_SERVICE_URL=http://localhost:8083
NOTIFICATION_SERVICE_URL=http://localhost:8084
FINANCE_SERVICE_URL=http://localhost:8085
DOCUMENT_SERVICE_URL=http://localhost:8086
MEAL_SERVICE_URL=http://localhost:8087
TRAVEL_SERVICE_URL=http://localhost:8088
AI_SERVICE_URL=http://localhost:8089
KG_SERVICE_URL=http://localhost:8090
ANALYTICS_SERVICE_URL=http://localhost:8091

# Firebase project id (use demo-niki for the local Auth emulator).
FIREBASE_PROJECT_ID=demo-niki

# Local dev: point the Admin SDK at the Auth emulator (no credentials needed).
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Real project (staging/prod) options instead of the emulator:
#  - paste the service account JSON on a single line, OR
#  - omit and rely on Application Default Credentials (Cloud Run).
FIREBASE_SERVICE_ACCOUNT=
