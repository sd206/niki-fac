EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Local Auth emulator (demo project, no real credentials needed):
EXPO_PUBLIC_FIREBASE_API_KEY=demo-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=demo-niki.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=demo-niki
EXPO_PUBLIC_FIREBASE_APP_ID=demo-app
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_URL=http://localhost:9099
# For a real project, replace the values above and remove the EMULATOR_URL line.

# Google OAuth client IDs (from Google Cloud Console / Firebase).
# webClientId is also used by Firebase to verify the Google ID token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
