{
  "expo": {
    "name": "Niki",
    "slug": "niki-family-os",
    "scheme": "niki",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.niki.app",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "ai.niki.app"
    },
    "plugins": ["expo-router", "expo-apple-authentication"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
